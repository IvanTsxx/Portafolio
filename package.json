{
  "name": "portafolio",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:portless": "portless portafolio next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "db:generate": "bun x prisma generate",
    "db:push": "bun x prisma db push",
    "db:migrate": "bun x prisma migrate dev",
    "db:studio": "bun x prisma studio",
    "db:reset": "bun x prisma migrate reset --force",
    "registry:build": "bun run ./scripts/build-registry.mts && shadcn build ./public/r/registry.json",
    "postinstall": "prisma generate",
    "deploy": "vercel build --prod && vercel deploy --prebuilt --prod"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@octokit/rest": "^22.0.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@react-symbols/icons": "^1.3.1",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@takumi-rs/image-response": "^0.73.1",
    "@tanstack/react-form": "^1.28.6",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "jotai": "^2.19.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.1.3",
    "shadcn": "^4.1.2",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shikijs/rehype": "^4.0.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "portless": "^0.9.6",
    "postcss": "^8",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "7.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx,!.agents/**,!.claude/**}": [
      "bun x ultracite fix"
    ]
  }
}
